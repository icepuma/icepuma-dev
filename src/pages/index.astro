---
import SectionHeading from "@/components/SectionHeading.astro";
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
import MinimalLayout from "@/layouts/MinimalLayout.astro";
import { getCollection, render } from "astro:content";

const stackEntries = (await getCollection("stack")).sort(
	(a, b) => Number(a.id) - Number(b.id),
);
const calendarEntries = (await getCollection("calendar")).sort(
	(a, b) => Number(a.id) - Number(b.id),
);
const socialEntries = (await getCollection("socials")).sort(
	(a, b) => Number(a.id) - Number(b.id),
);

const projectEntries = await getCollection("projects");
const projects = await Promise.all(
	projectEntries
		.sort((a, b) => a.data.order - b.data.order)
		.map(async (entry) => {
			const { Content } = await render(entry);
			return { data: entry.data, Content };
		}),
);

const musicLinks = [
	{
		name: "Tortuga Room",
		url: "https://www.youtube.com/@tortugaroom",
		genre: "Electronic",
		description:
			"Seoul-based mix platform with a loose underground-party feel, sharing DJ sessions that move between deep, psychedelic, and more atmospheric electronic sets.",
	},
	{
		name: "Yoyaku Record Store",
		url: "https://www.youtube.com/@yoyakurecordstore",
		genre: "Minimal",
		description:
			"Paris record store and label hub focused on electronic music, pairing a large vinyl catalog with mixes, artist sessions, and record culture from its 18th arrondissement base.",
	},
	{
		name: "EPHIMERA Tulum",
		url: "https://www.youtube.com/@EPHIMERATulum",
		genre: "Organic house",
		description:
			"Tulum-born audio-visual project streaming live DJ sets from natural locations and pushing the electronic sound of the Mexican Caribbean outward.",
	},
	{
		name: "RE: ANALOG",
		url: "https://www.youtube.com/@REANALOG",
		genre: "Disco",
		description:
			"Vinyl-centered channel and studio pairing improvised listening sessions with guest DJ sets, record culture, and a warm crate-digging atmosphere.",
	},
	{
		name: "Stil vor Talent",
		url: "https://www.youtube.com/@StilvorTalentTv",
		genre: "House",
		description:
			"Berlin label and event platform sharing artist releases, DJ clips, and dancefloor moments from its house-leaning electronic orbit.",
	},
	{
		name: "Yuna Room",
		url: "https://www.youtube.com/@Twilight441",
		genre: "Deep house",
		description:
			"Playlist-and-mix channel moving from deep house into softer late-night selections, including pop, R&B, and groove-heavy listening sessions.",
	},
	{
		name: "L'atelier de Musique",
		url: "https://www.youtube.com/@Latelier__de__Musique",
		genre: "Jazz-funk",
		description:
			"Record-driven channel built around themed vinyl episodes that drift through psychedelic soul, disco, jazz-funk, and other dusty global grooves.",
	},
	{
		name: "European Metal Channel",
		url: "https://www.youtube.com/@EuropeanMetalChannelOfficial",
		genre: "Metal",
		description:
			"Long-running curation channel spotlighting new European metal releases, scene roundups, and country-spanning band selections.",
	},
] as const;
const musicPageSize = 5;
const musicPages = Array.from(
	{ length: Math.ceil(musicLinks.length / musicPageSize) },
	(_, pageIndex) =>
		musicLinks.slice(
			pageIndex * musicPageSize,
			(pageIndex + 1) * musicPageSize,
		),
);
const stackPageSize = 5;

const navItems = [
	{ id: "about", label: "About", num: "01" },
	{ id: "stack", label: "Stack", num: "02" },
	{ id: "calendar", label: "Calendar", num: "03" },
	{ id: "projects", label: "Projects", num: "04" },
	{ id: "music", label: "Music", num: "05" },
	{ id: "social", label: "Social", num: "06" },
];
---

<MinimalLayout
	title="icepuma.dev"
	description="Software Developer — Berlin, Germany"
>
	<header
		class="fixed left-0 right-0 top-0 z-50 bg-background/90 backdrop-blur-sm"
	>
		<div class="flex items-center justify-between px-6 py-3">
			<nav
				class="flex items-center gap-4 font-mono text-xs uppercase tracking-widest sm:gap-5"
				aria-label="Navigation"
			>
				{
					navItems.map((item) => (
						<a
							href={`#${item.id}`}
							data-nav-link
							data-section={item.id}
							data-active="false"
							class="text-muted-foreground transition-colors hover:text-foreground data-[active=true]:text-primary"
						>
							<span class="text-muted-foreground/40">
								{item.num}
							</span>
							<span class="hidden sm:inline">
								{" "}
								{item.label}
							</span>
						</a>
					))
				}
			</nav>
			<ThemeSwitcher />
		</div>
	</header>

	<main class="mx-auto max-w-3xl px-6 pb-20">
		<!-- 01 About -->
		<section
			id="about"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading num="01" title="About" />
				<p class="mt-6 text-xl font-semibold text-foreground">
					Stefan Ruzitschka
				</p>
				<p class="mt-1 font-mono text-sm text-muted-foreground">
					Senior DevOps Engineer · Berlin, Germany
				</p>
				<p class="mt-6 text-muted-foreground">
					Senior Software & DevOps Engineer with 15+ years of
					experience shipping end-to-end. Specializing in
					high-reliability systems, platform engineering, and
					monolith-to-microservices migrations.
				</p>
			</div>
		</section>

		<!-- 02 Stack -->
		<section
			id="stack"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading num="02" title="Stack" />
				<div class="mt-6">
					{
						stackEntries.map((entry, i) => (
							<div class="flex items-baseline gap-3 py-2">
								<span class="w-5 shrink-0 font-mono text-muted-foreground">
									{String(i + 1).padStart(2, "0")}
								</span>
								<div class="min-w-0 flex-1">
									<span class="font-medium text-foreground">
										{entry.data.category}
									</span>
									<p class="mt-0.5 text-sm text-muted-foreground">
										{
											Array.from(
												{
													length: Math.ceil(
														entry.data.items.length /
															stackPageSize,
													),
												},
												(_, chunkIndex) =>
													entry.data.items
														.slice(
															chunkIndex *
																stackPageSize,
															(chunkIndex + 1) *
																stackPageSize,
														)
														.join(", "),
											).map((line, lineIndex, lines) => (
												<span class="block">
													{`${line}${lineIndex < lines.length - 1 ? "," : ""}`}
												</span>
											))
										}
									</p>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- 03 Calendar -->
		<section
			id="calendar"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading
					num="03"
					title="Calendar"
					intro="My weekly open-source schedule — what I work on and when."
				/>
				<div class="mt-6">
					{
						calendarEntries.map((entry) => (
							<div class="flex items-baseline gap-3 py-2">
								<span class="w-10 shrink-0 font-mono text-primary">
									{entry.data.day}
								</span>
								{entry.data.url ? (
									<a
										href={entry.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-foreground transition-colors hover:text-primary"
									>
										{entry.data.focus}
									</a>
								) : (
									<span class="text-muted-foreground">
										{entry.data.focus}
									</span>
								)}
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- 04 Projects -->
		<section
			id="projects"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading
					num="04"
					title="Projects"
					intro="Things I build and maintain."
				/>
				<div class="mt-6">
					{
						projects.map(({ data, Content }, i) => (
							<a
								href={data.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group block py-2"
							>
								<div class="flex items-baseline gap-3">
									<span class="w-5 shrink-0 font-mono text-muted-foreground">
										{String(i + 1).padStart(2, "0")}
									</span>
									<div class="min-w-0 flex-1">
										<span class="font-medium text-foreground transition-colors group-hover:text-primary">
											{data.name}
										</span>
										<div class="mt-0.5 text-sm text-muted-foreground [&>p]:m-0">
											<Content />
										</div>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<!-- 05 Music -->
		<section
			id="music"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading
					num="05"
					title="Music"
					intro="Channels and record spaces worth keeping in rotation."
				/>
				<div class="mt-6" data-music-pagination>
					{
						musicPages.length > 1 && (
							<nav
								class="mb-4 flex items-center gap-4 font-mono text-xs uppercase tracking-widest"
								aria-label="Music pages"
							>
								{
									musicPages.map((_, pageIndex) => (
										<button
											type="button"
											data-music-page-button
											data-page-index={pageIndex}
											data-active={pageIndex === 0 ? "true" : "false"}
											aria-label={`Go to music page ${pageIndex + 1}`}
											aria-current={pageIndex === 0 ? "page" : "false"}
											class="text-muted-foreground transition-colors hover:text-foreground data-[active=true]:text-primary"
										>
											{String(pageIndex + 1).padStart(2, "0")}
										</button>
									))
								}
							</nav>
						)
					}

					{
						musicPages.map((page, pageIndex) => (
							<div
								data-music-page
								data-page-index={pageIndex}
								data-active={pageIndex === 0 ? "true" : "false"}
								class="data-[active=false]:hidden"
							>
								{
									page.map((link, itemIndex) => {
										const globalIndex =
											pageIndex * musicPageSize +
											itemIndex;

										return (
											<a
												href={link.url}
												target="_blank"
												rel="noopener noreferrer"
												class="group block py-2"
											>
												<div class="flex items-baseline gap-3">
													<span class="w-5 shrink-0 font-mono text-muted-foreground">
														{String(globalIndex + 1).padStart(
															2,
															"0",
														)}
													</span>
													<div class="min-w-0 flex-1">
														<div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
															<span class="font-medium text-foreground transition-colors group-hover:text-primary">
																{link.name}
															</span>
															<span class="font-mono text-xs uppercase tracking-widest text-primary">
																{link.genre}
															</span>
														</div>
														<p class="mt-1 text-sm text-muted-foreground">
															{link.description}
														</p>
													</div>
												</div>
											</a>
										);
									})
								}
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- 06 Social -->
		<section
			id="social"
			class="flex min-h-svh flex-col justify-center pb-12 pt-20"
		>
			<div>
				<SectionHeading
					num="06"
					title="Social"
					intro="Where to find me online."
				/>
				<div class="mt-6">
					{
						socialEntries.map((entry) => (
							<a
								href={entry.data.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group flex items-baseline gap-3 py-2"
							>
								<span class="w-24 shrink-0 font-mono text-primary">
									{entry.data.platform}
								</span>
								<span class="text-muted-foreground transition-colors group-hover:text-primary">
									{entry.data.handle}
								</span>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</main>

	<footer class="mx-auto max-w-3xl px-6 py-8">
		<p class="font-mono text-xs text-muted-foreground">
			icepuma.dev — {new Date().getFullYear()}
		</p>
	</footer>
</MinimalLayout>

<script>
	// Smooth scroll only on nav click, not globally
	function initSmoothScroll() {
		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		for (const link of document.querySelectorAll<HTMLAnchorElement>(
			"[data-nav-link]",
		)) {
			link.addEventListener("click", (e) => {
				const targetId = link.getAttribute("href")?.slice(1);
				const target = targetId
					? document.getElementById(targetId)
					: null;
				if (target) {
					e.preventDefault();
					target.scrollIntoView({
						behavior: prefersReducedMotion ? "instant" : "smooth",
					});
					history.replaceState(null, "", `#${targetId}`);
				}
			});
		}
	}

	function initNavTracking() {
		const navLinks =
			document.querySelectorAll<HTMLElement>("[data-nav-link]");
		const sections = document.querySelectorAll<HTMLElement>("section[id]");

		if (navLinks.length === 0 || sections.length === 0) return;

		function update() {
			const offset = 100;
			let activeId = "";

			for (const section of sections) {
				if (section.getBoundingClientRect().top <= offset) {
					activeId = section.id;
				}
			}

			for (const link of navLinks) {
				link.dataset.active =
					link.dataset.section === activeId ? "true" : "false";
			}
		}

		let ticking = false;
		window.addEventListener(
			"scroll",
			() => {
				if (!ticking) {
					requestAnimationFrame(() => {
						update();
						ticking = false;
					});
					ticking = true;
				}
			},
			{ passive: true },
		);

		update();
	}

	function initMusicPagination() {
		const root =
			document.querySelector<HTMLElement>("[data-music-pagination]");
		if (!root) return;

		const pages = Array.from(
			root.querySelectorAll<HTMLElement>("[data-music-page]"),
		);
		const pageButtons = Array.from(
			root.querySelectorAll<HTMLButtonElement>(
				"[data-music-page-button]",
			),
		);

		if (pages.length <= 1 || pageButtons.length !== pages.length) {
			return;
		}

		let currentPage = 0;

		function renderPage() {
			for (const page of pages) {
				page.dataset.active =
					Number(page.dataset.pageIndex) === currentPage
						? "true"
						: "false";
			}

			for (const button of pageButtons) {
				const isActive =
					Number(button.dataset.pageIndex) === currentPage;
				button.dataset.active = isActive ? "true" : "false";
				button.setAttribute(
					"aria-current",
					isActive ? "page" : "false",
				);
			}
		}

		for (const button of pageButtons) {
			button.addEventListener("click", () => {
				currentPage = Number(button.dataset.pageIndex) || 0;
				renderPage();
			});
		}

		renderPage();
	}

	initSmoothScroll();
	initNavTracking();
	initMusicPagination();
</script>
